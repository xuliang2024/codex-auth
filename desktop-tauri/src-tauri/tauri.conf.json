{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Accounts for Codex",
  "version": "0.2.2",
  "identifier": "com.loongphy.codex-auth-desktop",
  "build": {
    "beforeDevCommand": "npm run prepare",
    "beforeBuildCommand": "npm run prepare",
    "frontendDist": "../frontend-dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Accounts for Codex",
        "url": "renderer/index.html",
        "width": 1068,
        "height": 722,
        "minWidth": 620,
        "minHeight": 480,
        "backgroundColor": "#0d1017",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "../../desktop/build/icon.png",
      "../../desktop/build/icon.icns",
      "../../desktop/build/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
